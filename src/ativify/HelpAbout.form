                <Property name="rows" type="int" value="5"/>
                <Property name="text" type="java.lang.String" value="Sobre o Sistema &#x2013; Ativify &#x2139;&#xfe0f;&#xa;Bem-vindo ao Ativify, o sistema de gest&#xe3;o de ativos fixos pensado especialmente para pequenas empresas e startups! \ud83d\ude80&#xa;&#xa;Nosso objetivo &#xe9; facilitar o controle patrimonial, oferecendo ferramentas simples, intuitivas e eficientes para o registro, acompanhamento e deprecia&#xe7;&#xe3;o dos bens da sua empresa. \ud83d\udcca\ud83d\udcc9&#xa;&#xa;Este software foi desenvolvido como parte do projeto acad&#xea;mico do 4&#xba; bimestre do curso de T.I. no Centro Universit&#xe1;rio Senac.&#xa;&#xa;Desenvolvedores \ud83d\udc68&#x200d;\ud83d\udcbb\ud83d\udc69&#x200d;\ud83d\udcbb&#xa;Diego William Silva&#xa;&#xa;Jo&#xe3;o Gabriel de Oliveira Carneiro&#xa;&#xa;Nicolas Reimberg de Moura&#xa;&#xa;Rafael Silva Fernandes&#xa;&#xa;Orientador: Alexandre Pereira da Silva&#xa;\ud83d\udccd S&#xe3;o Paulo &#x2013; 2025" containsInvalidXMLChars="true"/>
                <Property name="wrapStyleWord" type="boolean" value="true"/>
                <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                  <Border info="null"/>
                </Property>
                <Property name="focusable" type="boolean" value="false"/>
              </Properties>
